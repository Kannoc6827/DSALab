/*
 * Cài đặt 5 thuật toán sắp xếp bằng C++:
 *   1. Selection Sort
 *   2. Insertion Sort
 *   3. Bubble Sort
 *   4. Quick Sort
 *   5. Heap Sort
 *
 * Dãy đầu vào : {3, -12, 14, 9, 11, -50, -100}
 * Kết quả mong đợi (tăng dần): {-100, -50, -12, 3, 9, 11, 14}
 */

#include <iostream>
#include <vector>
#include <algorithm>   // std::swap
using namespace std;

// ─────────────────────────────────────────────
// Hàm tiện ích: in mảng
// ─────────────────────────────────────────────
void printArray(const string& label, const vector<int>& a) {
    cout << label << ": [";
    for (int i = 0; i < (int)a.size(); i++) {
        cout << a[i];
        if (i < (int)a.size() - 1) cout << ", ";
    }
    cout << "]\n";
}

// ─────────────────────────────────────────────
// 1. SELECTION SORT
//
// Ý tưởng: Chia mảng thành 2 phần (đã sắp xếp | chưa sắp xếp).
// Mỗi vòng lặp, tìm phần tử nhỏ nhất trong phần chưa sắp xếp
// và hoán đổi nó về đầu phần đó.
//
// Độ phức tạp:
//   Thời gian: O(n²) mọi trường hợp
//   Không gian: O(1)
// ─────────────────────────────────────────────
vector<int> selectionSort(vector<int> a) {
    int n = a.size();
    for (int i = 0; i < n - 1; i++) {
        int minIdx = i;
        for (int j = i + 1; j < n; j++) {
            if (a[j] < a[minIdx])
                minIdx = j;
        }
        if (minIdx != i)
            swap(a[i], a[minIdx]);
    }
    return a;
}

// ─────────────────────────────────────────────
// 2. INSERTION SORT
//
// Ý tưởng: Duyệt từ trái sang phải. Với mỗi phần tử, chèn nó
// vào đúng vị trí trong đoạn đã được sắp xếp ở phía trước.
//
// Độ phức tạp:
//   Thời gian tốt nhất: O(n)  — dãy đã sắp xếp
//   Thời gian xấu nhất: O(n²) — dãy ngược thứ tự
//   Không gian: O(1)
// ─────────────────────────────────────────────
vector<int> insertionSort(vector<int> a) {
    int n = a.size();
    for (int i = 1; i < n; i++) {
        int key = a[i];
        int j = i - 1;
        while (j >= 0 && a[j] > key) {
            a[j + 1] = a[j];
            j--;
        }
        a[j + 1] = key;
    }
    return a;
}

// ─────────────────────────────────────────────
// 3. BUBBLE SORT
//
// Ý tưởng: Liên tục duyệt mảng, so sánh từng cặp phần tử liền kề
// và hoán đổi nếu sai thứ tự. Phần tử lớn nhất dần "nổi" về cuối.
// Cờ `swapped` giúp dừng sớm nếu dãy đã được sắp xếp.
//
// Độ phức tạp:
//   Thời gian tốt nhất: O(n)  — dãy đã sắp xếp (nhờ cờ swapped)
//   Thời gian xấu nhất: O(n²) — dãy ngược thứ tự
//   Không gian: O(1)
// ─────────────────────────────────────────────
vector<int> bubbleSort(vector<int> a) {
    int n = a.size();
    for (int i = 0; i < n - 1; i++) {
        bool swapped = false;
        for (int j = 0; j < n - 1 - i; j++) {
            if (a[j] > a[j + 1]) {
                swap(a[j], a[j + 1]);
                swapped = true;
            }
        }
        if (!swapped) break;   // Dãy đã sắp xếp, dừng sớm
    }
    return a;
}

// ─────────────────────────────────────────────
// 4. QUICK SORT
//
// Ý tưởng: Chọn một pivot (phần tử cuối), phân vùng mảng thành
// 2 nửa (bên trái <= pivot, bên phải > pivot), rồi đệ quy sắp
// xếp từng nửa. Dùng Lomuto partition scheme.
//
// Độ phức tạp:
//   Thời gian tốt/trung bình: O(n log n)
//   Thời gian xấu nhất: O(n²) — pivot luôn là min/max
//   Không gian: O(log n) — stack đệ quy
// ─────────────────────────────────────────────
int partition(vector<int>& a, int lo, int hi) {
    int pivot = a[hi];
    int i = lo;
    for (int j = lo; j < hi; j++) {
        if (a[j] <= pivot) {
            swap(a[i], a[j]);
            i++;
        }
    }
    swap(a[i], a[hi]);
    return i;
}

void quickSortHelper(vector<int>& a, int lo, int hi) {
    if (lo < hi) {
        int pivotIdx = partition(a, lo, hi);
        quickSortHelper(a, lo, pivotIdx - 1);
        quickSortHelper(a, pivotIdx + 1, hi);
    }
}

vector<int> quickSort(vector<int> a) {
    quickSortHelper(a, 0, (int)a.size() - 1);
    return a;
}

// ─────────────────────────────────────────────
// 5. HEAP SORT
//
// Ý tưởng: Gồm 2 giai đoạn:
//   (1) Xây dựng max-heap từ mảng — O(n).
//   (2) Lần lượt trích phần tử lớn nhất (gốc heap) về cuối
//       và heapify lại phần còn lại — n lần × O(log n).
//
// Độ phức tạp:
//   Thời gian: O(n log n) mọi trường hợp
//   Không gian: O(1) — sắp xếp tại chỗ
// ─────────────────────────────────────────────
void heapify(vector<int>& a, int n, int i) {
    int largest = i;
    int left    = 2 * i + 1;
    int right   = 2 * i + 2;

    if (left  < n && a[left]  > a[largest]) largest = left;
    if (right < n && a[right] > a[largest]) largest = right;

    if (largest != i) {
        swap(a[i], a[largest]);
        heapify(a, n, largest);
    }
}

vector<int> heapSort(vector<int> a) {
    int n = a.size();

    // Giai đoạn 1: Xây max-heap
    for (int i = n / 2 - 1; i >= 0; i--)
        heapify(a, n, i);

    // Giai đoạn 2: Trích từng phần tử lớn nhất
    for (int i = n - 1; i > 0; i--) {
        swap(a[0], a[i]);   // gốc (max) về cuối
        heapify(a, i, 0);   // khôi phục heap
    }
    return a;
}

// ─────────────────────────────────────────────
// MAIN — DEMO
// ─────────────────────────────────────────────
int main() {
    vector<int> data = {3, -12, 14, 9, 11, -50, -100};

    printArray("Dãy đầu vào  ", data);
    cout << string(45, '-') << "\n";

    printArray("Selection Sort", selectionSort(data));
    printArray("Insertion Sort", insertionSort(data));
    printArray("Bubble Sort   ", bubbleSort(data));
    printArray("Quick Sort    ", quickSort(data));
    printArray("Heap Sort     ", heapSort(data));

    return 0;
}
